{
  "name": "fc-manager-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --host",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "tsc": "tsc --noEmit --project tsconfig.app.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "prepare": "husky",
    "precommit": "bun run tsc && lint-staged",
    "db:login": "npx supabase login",
    "db:generate": "dotenv cross-var npx supabase gen types typescript --project-id %SUPABASE_PROJECT_ID% --schema public > src/database-generated.types.ts"
  },
  "dependencies": {
    "@mantine/charts": "^9.0.0",
    "@mantine/core": "^9.0.0",
    "@mantine/dates": "^9.0.0",
    "@mantine/form": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/modals": "^9.0.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-table": "^8.21.3",
    "@unocss/reset": "^66.6.7",
    "countup.js": "^2.8.0",
    "dayjs": "^1.11.20",
    "jotai": "^2.19.0",
    "lodash-es": "^4.17.23",
    "react": "^19.2.4",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "type-fest": "^5.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.0",
    "@iconify-json/mdi": "^1.2.3",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/babel__core": "^7.20.5",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-icons": "^66.6.7",
    "@unocss/preset-wind3": "^66.6.7",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-var": "^1.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jotai-babel": "^0.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.1",
    "supabase": "^2.84.5",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.0",
    "unocss": "^66.6.7",
    "vite": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  }
}
